{
  "manifest_version": 3,
  "name": "QuickVerse",
  "version": "1.0.0",
  "description": "Browse and copy Bible verses in Tamil (TOVBSI) and English (NIV, AMP) — one-click paste into Google Docs",
  "author": "Your Name",
  "homepage_url": "https://github.com/your-username/bible-extension",
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Bible Verse Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Open Bible Verse Extractor"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
